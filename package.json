{
  "name": "insta-gen",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --port 4000",
    "watcher": "tsx -r dotenv/config services/runWatcher.ts",
    "worker": "tsx -r dotenv/config services/runWorker.ts",
    "dev:all": "concurrently \"npm run watcher\" \"npm run worker\" \"npm run dev\"",
    "start:all": "concurrently \"npm run watcher\" \"npm run worker\" \"npm run start\""
  },
  "dependencies": {
    "@dropb/ffprobe": "^3.0.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "lodash.debounce": "^4.0.8",
    "next": "16.2.4",
    "prisma-extension-random": "^0.2.2",
    "range-parser": "^1.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.21",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.14",
    "baseline-browser-mapping": "^2.10.0",
    "fluent-ffmpeg": "^2.1.3",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.14"
  }
}

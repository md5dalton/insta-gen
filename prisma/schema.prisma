model Tag {
    id String @id
    name String
    media MediaTag[]
}

model MediaTag {
    id String @id
    // id Int @id @default(autoincrement())
    tagId String
    mediaId String

    tag Tag @relation(fields: [tagId], references: [id])
    media Media @relation(fields: [mediaId], references: [id])
}
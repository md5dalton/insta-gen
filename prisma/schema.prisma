// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
    provider = "prisma-client"
    output   = "./generated"
}
datasource db {
    provider = "postgresql"
}

model File {
    path    String @id
    // media   Media?
}

model RootCollection {
    id              String @id
    name            String
    path            String
    collections     Collection[]
}
model Collection {
    id          String @id
    name        String
    path        String
    owner       RootCollection @relation(fields: [ownerId], references: [id])
    ownerId     String
    users       User[]
}
model User {
    id          String @id
    name        String
    path        String
    picture     String?
    owner       Collection @relation(fields: [ownerId], references: [id])
    ownerId     String
    media       Media[]
}

enum MediaType {
    IMAGE
    VIDEO
}

model Media {
    id          String @id
    path        String @unique
    type        MediaType

    owner       User @relation(fields: [ownerId], references: [id])
    ownerId     String
    
    tags        MediaTag[]

    height      Int
    width       Int
    size        BigInt
    duration    String?
    bitrate     String?
    mktime      String

    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
}

model Tag {
    id      String @id
    name    String
    media   MediaTag[]
}

model MediaTag {
    id          String @id
    tagId       String
    mediaId     String

    tag         Tag @relation(fields: [tagId], references: [id])
    media       Media @relation(fields: [mediaId], references: [id])
}


model ProfileUser {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String
    name      String
    createdAt DateTime @default(now())
}

model Job {
    id          String   @id @default(uuid())
    type        String   // "media"
    payload     Json

    status      String   @default("pending") // pending | processing | done | failed
    attempts    Int      @default(0)

    priority    Int      @default(0) // videos > images
    dedupeKey   String?  @unique

    lockedAt    DateTime?
    availableAt DateTime @default(now())

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([status, availableAt])
}
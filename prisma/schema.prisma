// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model File {
    path String @id
    media Media?
}

model Collection {
    id String @id
    name String
    path String
    users User[]
}

model User {
    id String @id
    name String
    path String
    picture String
    owner Collection @relation(fields: [ownerId], references: [id])
    ownerId String
    posts Post[]
}

model Post {
    id String @id
    path String
    thumb String
    owner User @relation(fields: [ownerId], references: [id])
    ownerId String
    media Media[]
    tags PostTag[]
}

enum MediaType {
    IMAGE
    VIDEO
}

model Media {
    id String @id
    type MediaType

    owner Post @relation(fields: [ownerId], references: [id])
    file File @relation(fields: [filePath], references: [path])

    image Image?
    video Video?

    ownerId String
    filePath String @unique

    // @@index([imageId])
    // @@index([videoId])
}

model Image {
    id String @id
    media Media @relation(fields: [mediaImage], references: [id])
    mediaImage String @unique
}

model Video {
    id String @id
    media Media @relation(fields: [mediaVideo], references: [id])
    mediaVideo String @unique
}

model Tag {
    id String @id
    name String
    posts PostTag[]
}

model PostTag {
    id Int @id @default(autoincrement())
    postId String
    tagId String

    post Post @relation(fields: [postId], references: [id])
    tag Tag @relation(fields: [tagId], references: [id])
}
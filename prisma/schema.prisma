// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model File {
    path String @id
    media Media?
}

model RootCollection {
    id String @id
    name String
    path String
    collections Collection[]
}
model Collection {
    id String @id
    name String
    path String
    owner RootCollection @relation(fields: [ownerId], references: [id])
    ownerId String
    users User[]
}

model User {
    id String @id
    name String
    path String
    picture String
    owner Collection @relation(fields: [ownerId], references: [id])
    ownerId String
    posts Post[]
}

model Post {
    id String @id
    name String
    path String
    thumb String
    owner User @relation(fields: [ownerId], references: [id])
    ownerId String
    media Media[]
}

enum MediaType {
    IMAGE
    VIDEO
}

model Media {
    id String @id

    path String @unique
    // type MediaType

    owner Post @relation(fields: [ownerId], references: [id])
    file File @relation(fields: [path], references: [path])

    isVideo Boolean

    ownerId String
    tags MediaTag[]

    // @@index([imageId])
    // @@index([videoId])
}


// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
    provider = "prisma-client"
    output   = "./generated"
}
datasource db {
    provider = "postgresql"
}

model File {
    path    String @id
    // media   Media?
}

model RootCollection {
    id              String @id
    name            String
    path            String
    collections     Collection[]
}
model Collection {
    id          String @id
    name        String
    path        String
    owner       RootCollection @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    ownerId     String
    users       User[]
}
model User {
    id          String @id
    name        String
    path        String
    picture     String?
    owner       Collection @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    ownerId     String
    media       Media[]
}

enum MediaType {
    IMAGE
    VIDEO
}

model Media {
    id          String @id
    path        String @unique
    type        MediaType

    owner       User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    ownerId     String
    
    tags        MediaTag[]
    
    likes        Like[]
    saves        Save[]

    height      Int
    width       Int
    size        BigInt
    duration    String?
    bitrate     String?
    mktime      String

    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    random Float @default(dbgenerated("random()"))

    @@unique([mktime, id])
    @@index([type, random])
}

model Tag {
    id      String @id
    name    String
    media   MediaTag[]
}

model MediaTag {
    id          String @id
    tagId       String
    mediaId     String

    tag         Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)
    media       Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}
model Like {
    id        String   @id @default(cuid())

    mediaId   String
    userId    String

    createdAt DateTime @default(now())

    user  ProfileUser @relation(fields: [userId], references: [id], onDelete: Cascade)
    media Media       @relation(fields: [mediaId], references: [id], onDelete: Cascade)

    @@unique([userId, mediaId])

    @@index([userId, createdAt, id])
}
model Save {
    id        String   @id @default(cuid())

    mediaId   String
    userId    String

    createdAt DateTime @default(now())

    user  ProfileUser @relation(fields: [userId], references: [id], onDelete: Cascade)
    media Media       @relation(fields: [mediaId], references: [id], onDelete: Cascade)

    @@unique([userId, mediaId])

    @@index([userId, createdAt, id])
}

model ProfileUser {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String
    name      String


    likes        Like[]
    saves        Save[]

    createdAt DateTime @default(now())
}
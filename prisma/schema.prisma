// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model File {
    path String @id
    media Media?
}

model RootCollection {
    id String @id
    name String
    path String
    collections Collection[]
}
model Collection {
    id String @id
    name String
    path String
    owner RootCollection @relation(fields: [ownerId], references: [id])
    ownerId String
    users User[]
}

model User {
    id String @id
    name String
    path String
    picture String
    owner Collection @relation(fields: [ownerId], references: [id])
    ownerId String
    posts Post[]
}

model Post {
    id String @id
    name String
    path String
    thumb String
    owner User @relation(fields: [ownerId], references: [id])
    ownerId String
    media Media[]
}

enum MediaType {
    IMAGE
    VIDEO
}

model Media {
    id String @id

    path String @unique

    owner Post @relation(fields: [ownerId], references: [id])
    file File @relation(fields: [path], references: [path])

    isVideo Boolean

    ownerId String
    tags MediaTag[]

    metadata Metadata?

}

model Metadata {
    height Int
    width Int
    mktime DateTime
    portrait Boolean

    media Media @relation(fields: [mediaId], references: [id])
    mediaId String @id
}


model Tag {
    id String @id
    name String
    media MediaTag[]
}

model MediaTag {
    id String @id
    tagId String
    mediaId String

    tag Tag @relation(fields: [tagId], references: [id])
    media Media @relation(fields: [mediaId], references: [id])
}